# Neon PostgreSQL — connection string from Neon dashboard
DATABASE_URL="postgres://user:password@host/db-name"

# App URL (no trailing slash). Better Auth uses this as baseURL.
# Local:     http://localhost:5173
# Netlify:   https://your-site.netlify.app  (must match deployed URL exactly)
ORIGIN="http://localhost:5173"

# Better Auth — 32+ random characters; use a different secret in production
# Generate: openssl rand -base64 32
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
